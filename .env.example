# Copy to .env (NOT .env.local — both are gitignored) and fill in real values.
# NEVER commit a populated copy. See SECURITY.md.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key
# Service role key — NEVER expose to client. Server-only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# ── Fal AI (server-only — no NEXT_PUBLIC_ prefix!) ──────────────────────────
FAL_KEY=your_fal_ai_api_key

# ── ElevenLabs (per-teacher voice cloning) ──────────────────────────────────
ELEVENLABS_API_KEY=sk-...
# Legacy shared voice id — only used as a fallback when a teacher has no
# personal clone yet. Safe to leave unset on fresh installs.
ELEVENLABS_VOICE_ID=

# ── Modal services ──────────────────────────────────────────────────────────
MODAL_MANIM_URL=https://YOUR_WORKSPACE--lipclass-manim-render-animation.modal.run
MODAL_AUDIO_EXTRACT_URL=https://YOUR_WORKSPACE--lipclass-audio-extract-extract-audio.modal.run

# ── Vercel Blob (TTS uploads) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Pinecone + OpenAI (RAG) ─────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=lipclass-docs
OPENAI_API_KEY=

# ── Bunny Stream (optional video CDN) ───────────────────────────────────────
VIDEO_DELIVERY_PROVIDER=fal
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_PULL_ZONE=

# ── Vercel Cron (voice cleanup) ─────────────────────────────────────────────
CRON_SECRET=generate_a_random_long_string

# ── Finalize concurrency ────────────────────────────────────────────────────
LIPSYNC_CONCURRENCY=4
